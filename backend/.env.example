DATABASE_URL="postgresql://postgres:password@localhost:5433/athwart_loop?schema=public"
# REQUIRED. Must be a strong random string in production (>=32 bytes).
# Generate one with: `openssl rand -hex 32`
JWT_SECRET="CHANGE-ME-random-32-byte-string"
PORT=4000
NODE_ENV=development
GROQ_API_KEY="gsk_your_key_here"

# Comma-separated list of allowed frontend origins, e.g. https://your-app.vercel.app
# Leave empty for local dev only — production must set this explicitly.
CORS_ORIGIN=""

# File storage: "local" (dev default) or "supabase" (required once deployed to Render, no persistent disk)
STORAGE_PROVIDER="local"
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="uploads"

# Handbook Section 6 — n8n weekly-digest bearer. Empty disables the endpoint (503).
# Rotate quarterly. Set the same value in the n8n workflow's X-Digest-Token header.
DIGEST_TOKEN=""

# Handbook Phase 2 · P4 — semantic search embedding provider.
#   noop   (default) — no external calls, no embeddings computed
#   openai — text-embedding-3-small (1536 dim). Requires OPENAI_API_KEY.
EMBED_PROVIDER="noop"
OPENAI_API_KEY=""

